# ================================
# ARTISAN NOMADE – Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ================================

PORT=3001
NODE_ENV=development

# Whitelist du frontend (en prod: ton domaine réel)
FRONTEND_URL=http://127.0.0.1:5500

# Email de notification (Nodemailer via Gmail)
# Créer un "mot de passe d'application" Google :
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=artisannomade1@gmail.com
EMAIL_PASS=VOTRE_MOT_DE_PASSE_APP_GMAIL

# Email de l'admin (reçoit les notifications)
ADMIN_EMAIL=artisannomade1@gmail.com

# WhatsApp du vendeur
WHATSAPP_NUMBER=2290197998546

# Token d'accès à la page admin (IMPORTANT : change cette valeur en production,
# ne garde jamais la valeur par défaut du code une fois le site en ligne)
ADMIN_TOKEN=change-moi-en-production
